{
  "name": "electron-forge-template",
  "version": "0.1.0",
  "private": true,
  "description": "Electron Forge + Vite + React + TypeScript template with best practices",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "types:check": "tsc --noEmit",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "8.0.0-alpha.9",
    "@electron-forge/maker-dmg": "8.0.0-alpha.9",
    "@electron-forge/maker-zip": "8.0.0-alpha.9",
    "@electron-forge/plugin-fuses": "8.0.0-alpha.9",
    "@electron-forge/plugin-vite": "8.0.0-alpha.9",
    "@electron-forge/shared-types": "8.0.0-alpha.9",
    "@electron/fuses": "^2.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.3",
    "husky": "^9.1.7",
    "knip": "^6.16.0",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "npm run lint",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@11.6.0",
  "productName": "ElectronForgeTemplate"
}
